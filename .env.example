# Gemini API key — restrict to your domain in Google Cloud Console
# Direct key usage for local and mobile apps
GEMINI_API_KEY=your_gemini_key_here

# Groq API key for faster standard LLM processing
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API key for high-quality reasoning models (e.g. DeepSeek R1)
OPENROUTER_API_KEY=your_openrouter_api_key_here
